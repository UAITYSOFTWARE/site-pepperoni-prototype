---

<Layout title="Cardápio" description="Conheça o cardápio completo da Pizzaria Pepperoni. Mais de 70 sabores de pizzas, massas e porções em Maringá-PR.">

  <!-- Hero Title -->
  <header class="pt-36 pb-12 px-6 md:px-8 max-w-7xl mx-auto" id="cardapio-hero">
    <h1 class="font-headline font-black text-7xl md:text-9xl tracking-tighter leading-[0.85] uppercase mb-4 opacity-0">
      <span class="block">CARDÁPIO</span>
      <span class="block text-stroke opacity-30">COMPLETO</span>
    </h1>
    <p class="max-w-xl text-lg text-on-surface-variant font-medium mt-6 opacity-0" id="cardapio-sub">
      Mais de 70 sabores disponíveis no rodízio diário. Pizzas doces, salgadas, massas artesanais e porções para compartilhar.
    </p>
  </header>

  <div class="px-6 md:px-8 pb-24 max-w-7xl mx-auto">

    <!-- Category Chips -->
    <div class="flex flex-wrap gap-3 mb-16" id="category-chips">
      {categorias.map((cat, i) => (
        <button
          data-category={cat.id}
          class={`category-chip px-8 py-3 font-headline font-black uppercase text-sm tracking-wider transition-all duration-200 ${
            i === 0
              ? 'bg-primary text-on-primary'
              : 'bg-surface-container-high text-on-surface hover:bg-surface-container-highest'
          }`}
        >
          {cat.label}
        </button>
      ))}
    </div>

    <!-- PIZZAS SALGADAS -->
    <section id="section-salgadas" class="mb-24">
      <h2 class="font-headline font-black text-4xl uppercase mb-10 flex items-center gap-4" data-fade-left>
        <span class="w-12 h-1 bg-primary shrink-0"></span>
        Pizzas Salgadas
      </h2>

      <div class="grid grid-cols-1 md:grid-cols-12 gap-8" data-stagger>

        <!-- Featured Card (Pepperoni) -->
        {salgadas.filter(p => p.destaque).map((pizza) => (
          <div class="md:col-span-12 bg-surface-container overflow-hidden group relative flex flex-col md:flex-row items-center" data-stagger-item>
            <div class="p-10 flex-1 z-10">
              <span class="text-primary font-black uppercase tracking-widest text-xs mb-2 block">Destaque do Rodízio</span>
              <h3 class="font-headline font-black text-4xl uppercase mb-4">{pizza.name}</h3>
              <p class="text-on-surface-variant mb-6 text-base">{pizza.desc} O sabor que deu nome à casa.</p>
              <div class="flex gap-4 mb-6">
                <span class="flex items-center gap-1 text-xs font-bold uppercase text-on-surface/50">
                  <span class="material-symbols-outlined text-primary text-sm">local_pizza</span> Pizza Salgada
                </span>
                <span class="flex items-center gap-1 text-xs font-bold uppercase text-on-surface/50">
                  <span class="material-symbols-outlined text-primary text-sm">star</span> Mais Pedida
                </span>
              </div>
              <div class="text-3xl font-headline font-black text-primary">Incluso no Rodízio</div>
            </div>
            <div class="relative w-full md:w-1/3 h-72 md:h-full overflow-hidden bg-white flex items-center justify-center p-4">
              <img
                alt={`${pizza.name} — pizza artesanal`}
                class="w-full h-full object-contain group-hover:scale-110 transition-transform duration-700"
                src={pizza.img}
              />
            </div>
          </div>
        ))}

        <!-- All other salgadas -->
        {salgadas.filter(p => !p.destaque).map((pizza) => (
          <div class="md:col-span-4 bg-surface-container-low p-6 flex flex-col justify-between group hover:bg-surface-container transition-colors" data-stagger-item>
            <div>
              <div class="w-full h-40 mb-5 overflow-hidden flex items-center justify-center bg-white/95 p-3">
                <img
                  alt={pizza.name}
                  class="w-full h-full object-contain group-hover:scale-110 transition-transform duration-500"
                  src={pizza.img}
                  loading="lazy"
                />
              </div>
              <h3 class="font-headline font-black text-lg uppercase mb-2">{pizza.name}</h3>
              <p class="text-on-surface-variant text-sm mb-4">{pizza.desc}</p>
            </div>
            <div class="flex justify-between items-end">
              <div class="text-lg font-headline font-black text-primary">Rodízio</div>
              <span class="material-symbols-outlined text-primary opacity-40">local_pizza</span>
            </div>
          </div>
        ))}

      </div>
    </section>

    <!-- PIZZAS DOCES -->
    <section id="section-doces" class="mb-24 hidden">
      <h2 class="font-headline font-black text-4xl uppercase mb-10 flex items-center gap-4" data-fade-left>
        <span class="w-12 h-1 bg-primary shrink-0"></span>
        Pizzas Doces
      </h2>
      <div class="grid grid-cols-1 md:grid-cols-12 gap-8" data-stagger>
        {doces.map((item) => (
          <div class="md:col-span-4 bg-surface-container-low p-6 flex flex-col justify-between group hover:bg-surface-container transition-colors" data-stagger-item>
            <div>
              <div class="w-full h-40 mb-5 overflow-hidden flex items-center justify-center bg-white/95 p-3">
                <img
                  alt={item.name}
                  class="w-full h-full object-contain group-hover:scale-110 transition-transform duration-500"
                  src="/img/doce-placeholder.svg"
                  loading="lazy"
                />
              </div>
              <h3 class="font-headline font-black text-lg uppercase mb-2">{item.name}</h3>
              <p class="text-on-surface-variant text-sm mb-4">{item.desc}</p>
            </div>
            <div class="flex justify-between items-end">
              <div class="text-lg font-headline font-black text-primary">Rodízio</div>
              <span class="material-symbols-outlined text-primary opacity-40">cake</span>
            </div>
          </div>
        ))}
        <div class="md:col-span-4 bg-primary flex flex-col items-center justify-center p-10 text-center text-on-primary" data-stagger-item>
          <span class="material-symbols-outlined text-6xl mb-6" style="font-variation-settings: 'FILL' 1;">cake</span>
          <h4 class="font-headline font-black text-2xl uppercase leading-none mb-4">Sempre Uma<br/>Surpresa Doce</h4>
          <p class="font-bold text-sm uppercase tracking-widest opacity-80 mb-6">Sabores rotativos toda semana</p>
          <a href="https://wa.me/5544991566299" target="_blank" rel="noopener" class="border-2 border-on-primary px-6 py-3 font-headline font-black uppercase text-sm hover:bg-on-primary hover:text-primary transition-colors">
            Perguntar Hoje
          </a>
        </div>
      </div>
    </section>

    <!-- MASSAS -->
    <section id="section-massas" class="mb-24 hidden">
      <h2 class="font-headline font-black text-4xl uppercase mb-10 flex items-center gap-4" data-fade-left>
        <span class="w-12 h-1 bg-primary shrink-0"></span>
        Massas
      </h2>
      <div class="grid grid-cols-1 md:grid-cols-12 gap-8" data-stagger>
        {massas.map((item) => (
          <div class="md:col-span-4 bg-surface-container-low p-6 flex flex-col justify-between group hover:bg-surface-container transition-colors" data-stagger-item>
            <div>
              <div class="w-full h-40 mb-5 overflow-hidden flex items-center justify-center bg-white/95 p-3">
                <img
                  alt={item.name}
                  class="w-full h-full object-contain group-hover:scale-110 transition-transform duration-500"
                  src="/img/massa-placeholder.svg"
                  loading="lazy"
                />
              </div>
              <h3 class="font-headline font-black text-lg uppercase mb-2">{item.name}</h3>
              <p class="text-on-surface-variant text-sm mb-4">{item.desc}</p>
            </div>
            <div class="flex justify-between items-end">
              <div class="text-lg font-headline font-black text-primary">Rodízio</div>
              <span class="material-symbols-outlined text-primary opacity-40">restaurant</span>
            </div>
          </div>
        ))}
      </div>
    </section>

    <!-- PRATOS E PORÇÕES -->
    <section id="section-porcoes" class="mb-24 hidden">
      <h2 class="font-headline font-black text-4xl uppercase mb-10 flex items-center gap-4" data-fade-left>
        <span class="w-12 h-1 bg-primary shrink-0"></span>
        Pratos e Porções
      </h2>
      <div class="grid grid-cols-1 md:grid-cols-12 gap-8" data-stagger>
        {porcoes.map((item) => (
          <div class="md:col-span-4 bg-surface-container-low p-6 flex flex-col justify-between group hover:bg-surface-container transition-colors" data-stagger-item>
            <div>
              <div class="w-full h-40 mb-5 overflow-hidden flex items-center justify-center bg-white/95 p-3">
                <img
                  alt={item.name}
                  class="w-full h-full object-contain group-hover:scale-110 transition-transform duration-500"
                  src="/img/porcao-placeholder.svg"
                  loading="lazy"
                />
              </div>
              <h3 class="font-headline font-black text-lg uppercase mb-2">{item.name}</h3>
              <p class="text-on-surface-variant text-sm mb-4">{item.desc}</p>
            </div>
            <div class="flex justify-between items-end">
              <div class="text-lg font-headline font-black text-primary">Rodízio</div>
              <span class="material-symbols-outlined text-primary opacity-40">{item.icon}</span>
            </div>
          </div>
        ))}
      </div>
    </section>

    <!-- BEBIDAS -->
    <section id="section-bebidas" class="mb-24 hidden">
      <h2 class="font-headline font-black text-4xl uppercase mb-10 flex items-center gap-4" data-fade-left>
        <span class="w-12 h-1 bg-primary shrink-0"></span>
        Bebidas
      </h2>
      <div class="grid grid-cols-1 md:grid-cols-12 gap-8" data-stagger>
        {bebidas.map((item) => (
          <div class="md:col-span-4 bg-surface-container-low p-6 flex flex-col justify-between group hover:bg-surface-container transition-colors" data-stagger-item>
            <div>
              <div class="w-full h-40 mb-5 overflow-hidden flex items-center justify-center bg-white/95 p-3">
                <img
                  alt={item.name}
                  class="w-full h-full object-contain group-hover:scale-110 transition-transform duration-500"
                  src="/img/bebida-placeholder.svg"
                  loading="lazy"
                />
              </div>
              <h3 class="font-headline font-black text-lg uppercase mb-2">{item.name}</h3>
              <p class="text-on-surface-variant text-sm mb-4">{item.desc}</p>
            </div>
            <div class="flex justify-between items-end">
              <div class="text-lg font-headline font-black text-primary">Rodízio</div>
              <span class="material-symbols-outlined text-primary opacity-40">{item.icon}</span>
            </div>
          </div>
        ))}
      </div>
    </section>

    <!-- Rodízio CTA Banner -->
    <div class="bg-surface-container-highest p-10 md:p-14 flex flex-col md:flex-row items-center justify-between gap-8" data-fade-up>
      <div>
        <p class="text-primary font-headline font-black text-sm tracking-widest uppercase mb-2">Modalidade</p>
        <h3 class="font-headline font-black text-4xl md:text-5xl text-on-surface uppercase tracking-tighter leading-none">
          RODÍZIO DIÁRIO
        </h3>
        <p class="text-on-surface-variant font-medium mt-3">Todos os sabores à vontade • 18h30 às 22h30 • Todos os dias</p>
      </div>
      <a
        href="https://wa.me/5544991566299"
        target="_blank"
        rel="noopener noreferrer"
        class="bg-primary text-on-primary font-headline font-black uppercase tracking-tighter px-8 py-4 text-lg hover:scale-105 transition-transform brutalist-shadow shrink-0 flex items-center gap-2"
      >
        <span class="material-symbols-outlined">chat</span>
        Reservar Mesa
      </a>
    </div>

  </div>

</Layout>

<script>
  import gsap from 'gsap';

  // Hero animation
  const tl = gsap.timeline({ delay: 0.2, defaults: { ease: 'power4.out' } });
  tl.fromTo('#cardapio-hero h1', { opacity: 0, y: 80 }, { opacity: 1, y: 0, duration: 1 })
    .fromTo('#cardapio-sub', { opacity: 0, y: 30 }, { opacity: 1, y: 0, duration: 0.7 }, '-=0.5');

  // ─── Hydrate from Supabase ───
  import { getCardapio } from '../scripts/admin-store';
  const adminItems = await getCardapio();
  if (adminItems.length > 0) {
    const grouped: Record<string, typeof adminItems> = {};
    adminItems.forEach(item => {
      if (!grouped[item.categoria]) grouped[item.categoria] = [];
      grouped[item.categoria].push(item);
    });

    const escapeHtml = (s: string) => { const d = document.createElement('div'); d.textContent = s; return d.innerHTML; };

    const buildCards = (items: typeof adminItems) => items.map(item => `
      <div class="md:col-span-4 bg-surface-container-low p-8 flex flex-col justify-between group" data-stagger-item>
        <div>
          ${item.imagem_url ? `<div class="w-full h-44 mb-6 overflow-hidden flex items-center justify-center bg-white/95 p-3"><img alt="${escapeHtml(item.titulo)}" class="w-full h-full object-contain group-hover:scale-110 transition-transform duration-500" src="${escapeHtml(item.imagem_url)}" loading="lazy" /></div>` : ''}
          <h3 class="font-headline font-black text-lg uppercase mb-2">${escapeHtml(item.titulo)}</h3>
          <p class="text-on-surface-variant text-sm mb-4">${escapeHtml(item.descricao)}</p>
        </div>
        <div class="flex justify-between items-end">
          <div class="text-lg font-headline font-black text-primary">Rodízio</div>
          <span class="material-symbols-outlined text-primary opacity-40">local_pizza</span>
        </div>
      </div>
    `).join('');

    for (const [cat, items] of Object.entries(grouped)) {
      const section = document.getElementById(`section-${cat}`);
      if (!section) continue;
      const grid = section.querySelector('.grid');
      if (grid) grid.innerHTML = buildCards(items);
    }
  }

  // Category chip switching
  const chips = document.querySelectorAll<HTMLButtonElement>('.category-chip');
  const sections: Record<string, HTMLElement | null> = {
    salgadas: document.getElementById('section-salgadas'),
    doces: document.getElementById('section-doces'),
    massas: document.getElementById('section-massas'),
    porcoes: document.getElementById('section-porcoes'),
    bebidas: document.getElementById('section-bebidas'),
  };

  chips.forEach((chip) => {
    chip.addEventListener('click', () => {
      const target = chip.dataset.category as string;

      // Update chip styles
      chips.forEach((c) => {
        c.classList.remove('bg-primary', 'text-on-primary');
        c.classList.add('bg-surface-container-high', 'text-on-surface');
      });
      chip.classList.add('bg-primary', 'text-on-primary');
      chip.classList.remove('bg-surface-container-high', 'text-on-surface');

      // Show/hide sections with animation
      Object.entries(sections).forEach(([key, section]) => {
        if (!section) return;
        if (key === target) {
          section.classList.remove('hidden');
          gsap.fromTo(section, { opacity: 0, y: 30 }, { opacity: 1, y: 0, duration: 0.5, ease: 'power3.out' });
        } else {
          section.classList.add('hidden');
        }
      });
    });
  });
</script>
