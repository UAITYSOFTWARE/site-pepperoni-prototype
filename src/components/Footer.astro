---
---

<footer class="relative w-full border-t border-on-surface/10 overflow-hidden">
  <!-- Background texture image -->
  <div class="absolute inset-0 bg-[url('/img/bg-rodape.jpg')] bg-cover bg-bottom bg-no-repeat" aria-hidden="true"></div>
  <!-- Dark overlay for readability -->
  <div class="absolute inset-0 bg-black/75" aria-hidden="true"></div>
  <!-- Content -->
  <div class="relative z-10 py-16 px-6 md:px-8">
  <div class="grid grid-cols-1 md:grid-cols-4 gap-12 max-w-7xl mx-auto">

    <!-- Brand -->
    <div class="md:col-span-1">
      <div class="text-2xl font-black text-primary dark:text-brand-yellow mb-4 font-headline uppercase tracking-tighter">
        Pizzaria<br/>Pepperoni
      </div>
      <p class="text-white/70 text-sm leading-relaxed max-w-xs font-body">
        Mais de 70 sabores de pizzas doces e salgadas, massas e porções. Rodízio todos os dias em Maringá-PR.
      </p>
    </div>

    <!-- Navigation -->
    <div class="flex flex-col gap-4">
      <h5 class="text-green font-headline font-black uppercase tracking-widest text-xs mb-2">Explorar</h5>
      <a class="text-white/70 hover:text-green transition-all font-body font-medium text-sm" href="/cardapio">Cardápio</a>
      <a class="text-white/70 hover:text-green transition-all font-body font-medium text-sm" href="/sobre">A Pizzaria</a>
      <a class="text-white/70 hover:text-green transition-all font-body font-medium text-sm" href="/promocoes">Promoções</a>
      <a class="text-white/70 hover:text-green transition-all font-body font-medium text-sm" href="/contato">Localização</a>
    </div>

    <!-- Contact -->
    <div class="flex flex-col gap-4">
      <h5 class="text-green font-headline font-black uppercase tracking-widest text-xs mb-2">Contato</h5>
      <a href="tel:4432225951" class="text-white/70 hover:text-green transition-all font-body font-medium text-sm flex items-center gap-2">
        <span class="material-symbols-outlined text-green text-base">phone</span>
        (44) 3222-5951
      </a>
      <a href="tel:4430315951" class="text-white/70 hover:text-green transition-all font-body font-medium text-sm flex items-center gap-2">
        <span class="material-symbols-outlined text-green text-base">phone</span>
        (44) 3031-5951
      </a>
      <a href="https://wa.me/5544991566299" target="_blank" rel="noopener" class="text-white/70 hover:text-green transition-all font-body font-medium text-sm flex items-center gap-2">
        <span class="material-symbols-outlined text-green text-base">chat</span>
        (44) 99156-6299
      </a>
    </div>

    <!-- Social & Hours -->
    <div class="flex flex-col gap-4">
      <h5 class="text-green font-headline font-black uppercase tracking-widest text-xs mb-2">Funcionamento</h5>
      <p class="text-white/70 font-body text-sm">
        <span class="font-bold text-white/90">Todos os dias</span><br/>
        18h30 às 22h30
      </p>
      <div class="flex gap-3 mt-2">
        <a
          href="https://www.instagram.com/pizzariapepperonimga"
          target="_blank"
          rel="noopener"
          class="w-11 h-11 flex items-center justify-center bg-white/10 hover:bg-green hover:text-white text-green transition-all duration-300"
          aria-label="Instagram"
        >
          <span class="material-symbols-outlined text-lg">photo_camera</span>
        </a>
        <a
          href="https://wa.me/5544991566299"
          target="_blank"
          rel="noopener"
          class="w-11 h-11 flex items-center justify-center bg-white/10 hover:bg-green hover:text-white text-green transition-all duration-300"
          aria-label="WhatsApp"
        >
          <span class="material-symbols-outlined text-lg">chat</span>
        </a>
      </div>
    </div>

  </div>

  <div class="max-w-7xl mx-auto mt-16 pt-8 border-t border-white/10 flex flex-col md:flex-row justify-between items-center gap-4">
    <p class="font-body font-medium text-white/50 text-xs tracking-widest uppercase">
      © 2026 <a href="https://uaity.com" target="_blank" rel="noopener noreferrer" class="hover:text-green transition-colors">UAITY TECNOLOGIA</a>. TODOS OS DIREITOS RESERVADOS.
    </p>
    <div class="flex gap-6 text-white/50 text-xs font-bold uppercase tracking-tighter">
      <span>Av. Rio Branco 56 — Maringá-PR</span>
    </div>
  </div>
  </div>
</footer>
