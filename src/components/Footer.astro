<footer class="bg-surface w-full py-16 px-6 md:px-8 border-t border-on-surface/10">
  <div class="grid grid-cols-1 md:grid-cols-4 gap-12 max-w-7xl mx-auto">

    <!-- Brand -->
    <div class="md:col-span-1">
      <div class="text-2xl font-black text-primary mb-4 font-headline uppercase tracking-tighter">
        Pizzaria<br/>Pepperoni
      </div>
      <p class="text-on-surface/60 text-sm leading-relaxed max-w-xs font-body">
        Mais de 70 sabores de pizzas doces e salgadas, massas e porções. Rodízio todos os dias em Maringá-PR.
      </p>
    </div>

    <!-- Navigation -->
    <div class="flex flex-col gap-4">
      <h5 class="text-primary font-headline font-black uppercase tracking-widest text-xs mb-2">Explorar</h5>
      <a class="text-on-surface/60 hover:text-primary transition-all font-body font-medium text-sm" href="/cardapio">Cardápio</a>
      <a class="text-on-surface/60 hover:text-primary transition-all font-body font-medium text-sm" href="/sobre">A Pizzaria</a>
      <a class="text-on-surface/60 hover:text-primary transition-all font-body font-medium text-sm" href="/promocoes">Promoções</a>
      <a class="text-on-surface/60 hover:text-primary transition-all font-body font-medium text-sm" href="/contato">Localização</a>
    </div>

    <!-- Contact -->
    <div class="flex flex-col gap-4">
      <h5 class="text-primary font-headline font-black uppercase tracking-widest text-xs mb-2">Contato</h5>
      <a href="tel:4432225951" class="text-on-surface/60 hover:text-primary transition-all font-body font-medium text-sm flex items-center gap-2">
        <span class="material-symbols-outlined text-primary text-base">phone</span>
        (44) 3222-5951
      </a>
      <a href="tel:4430315951" class="text-on-surface/60 hover:text-primary transition-all font-body font-medium text-sm flex items-center gap-2">
        <span class="material-symbols-outlined text-primary text-base">phone</span>
        (44) 3031-5951
      </a>
      <a href="https://wa.me/5544991566299" target="_blank" rel="noopener" class="text-on-surface/60 hover:text-primary transition-all font-body font-medium text-sm flex items-center gap-2">
        <span class="material-symbols-outlined text-primary text-base">chat</span>
        (44) 99156-6299
      </a>
    </div>

    <!-- Social & Hours -->
    <div class="flex flex-col gap-4">
      <h5 class="text-primary font-headline font-black uppercase tracking-widest text-xs mb-2">Funcionamento</h5>
      <p class="text-on-surface/60 font-body text-sm">
        <span class="font-bold text-on-surface/80">Todos os dias</span><br/>
        18h30 às 22h30
      </p>
      <div class="flex gap-3 mt-2">
        <a
          href="https://www.instagram.com/pizzariapepperonimga"
          target="_blank"
          rel="noopener"
          class="w-11 h-11 flex items-center justify-center bg-surface-container hover:bg-primary hover:text-on-primary text-primary transition-all duration-300"
          aria-label="Instagram"
        >
          <span class="material-symbols-outlined text-lg">photo_camera</span>
        </a>
        <a
          href="https://wa.me/5544991566299"
          target="_blank"
          rel="noopener"
          class="w-11 h-11 flex items-center justify-center bg-surface-container hover:bg-primary hover:text-on-primary text-primary transition-all duration-300"
          aria-label="WhatsApp"
        >
          <span class="material-symbols-outlined text-lg">chat</span>
        </a>
      </div>
    </div>

  </div>

  <div class="max-w-7xl mx-auto mt-16 pt-8 border-t border-on-surface/5 flex flex-col md:flex-row justify-between items-center gap-4">
