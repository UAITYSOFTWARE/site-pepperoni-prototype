---
const navLinks = [
  { href: '/', label: 'Home' },
  { href: '/sobre', label: 'A Pizzaria' },
  { href: '/cardapio', label: 'Cardápio' },
  { href: '/promocoes', label: 'Promoções' },
  { href: '/contato', label: 'Contato' },
];

const currentPath = Astro.url.pathname;

// Normalize path: /cardapio/ === /cardapio
const normalize = (p: string) => p.replace(/\/$/, '') || '/';
const activePath = normalize(currentPath);
---

<nav
  id="navbar"
  role="navigation"
  aria-label="Navegação principal"
  class="fixed top-0 w-full z-50 bg-surface/90 backdrop-blur-md brutalist-shadow transition-all duration-300"
>
  <div class="flex justify-between items-center px-6 md:px-8 py-5 max-w-7xl mx-auto">

    <!-- Brand -->
    <a
      href="/"
      aria-label="Pizzaria Pepperoni — Página inicial"
      class="text-xl md:text-2xl font-black text-primary tracking-tighter uppercase font-headline hover:opacity-80 transition-opacity duration-200"
    >
      Pizzaria Pepperoni
    </a>

    <!-- Desktop Links -->
    <div class="hidden md:flex items-center gap-8" role="list">
      {navLinks.map((link) => {
        const isActive = normalize(link.href) === activePath;
        return (
          <a
            href={link.href}
            role="listitem"
            aria-current={isActive ? 'page' : undefined}
            class={`font-headline font-black uppercase tracking-tighter transition-all duration-200 hover:scale-105 hover:text-primary ${
              isActive
                ? 'text-primary border-b-4 border-primary pb-1'
                : 'text-on-surface'
            }`}
          >
            {link.label}
          </a>
        );
      })}
    </div>

    <div class="flex items-center gap-3">
      <!-- Theme Toggle -->
      <button
        id="theme-toggle"
        class="p-2 text-on-surface-variant hover:text-primary transition-colors"
        aria-label="Alternar tema claro/escuro"
        title="Alternar tema"
      >
        <span class="material-symbols-outlined text-xl" id="theme-icon" aria-hidden="true">dark_mode</span>
      </button>

      <!-- CTA -->
      <a
        href="https://wa.me/5544991566299"
        target="_blank"
        rel="noopener noreferrer"
        aria-label="Reservar mesa via WhatsApp"
        class="hidden md:flex items-center gap-2 bg-primary text-on-primary font-headline font-black uppercase tracking-tighter px-5 py-3 text-sm hover:scale-105 hover:brightness-110 active:scale-95 transition-all duration-200 brutalist-shadow"
      >
        <span class="material-symbols-outlined text-base" aria-hidden="true">chat</span>
        Reservar Mesa
      </a>
    </div>

    <!-- Mobile Menu Button -->
    <button
      id="menu-toggle"
      class="md:hidden text-primary p-2 hover:opacity-80 transition-opacity"
      aria-label="Abrir menu de navegação"
      aria-expanded="false"
      aria-controls="mobile-menu"
    >
      <span class="material-symbols-outlined text-3xl" id="menu-icon" aria-hidden="true">menu</span>
    </button>
  </div>

  <!-- Mobile Menu -->
  <div
    id="mobile-menu"
    role="menu"
    aria-label="Menu mobile"
    class="hidden md:hidden bg-surface-container-low border-t border-on-surface/10"
  >
    <div class="flex flex-col px-6 py-6 gap-4">
      {navLinks.map((link) => {
        const isActive = normalize(link.href) === activePath;
        return (
          <a
            href={link.href}
            role="menuitem"
            aria-current={isActive ? 'page' : undefined}
            class={`font-headline font-black uppercase tracking-tighter text-lg transition-colors duration-200 py-1 ${
              isActive ? 'text-primary' : 'text-on-surface hover:text-primary'
            }`}
          >
            {link.label}
          </a>
        );
      })}
      <a
        href="https://wa.me/5544991566299"
        target="_blank"
        rel="noopener noreferrer"
        class="mt-2 bg-primary text-on-primary font-headline font-black uppercase tracking-tighter px-5 py-4 text-center flex items-center justify-center gap-2"
      >
        <span class="material-symbols-outlined text-base" aria-hidden="true">chat</span>
        Reservar Mesa
      </a>
    </div>
  </div>
</nav>

<script>
  const toggle = document.getElementById('menu-toggle') as HTMLButtonElement | null;
  const menu = document.getElementById('mobile-menu');
  const icon = document.getElementById('menu-icon');

  toggle?.addEventListener('click', () => {
    const isOpen = !menu?.classList.contains('hidden');
    menu?.classList.toggle('hidden', isOpen);
    if (icon) icon.textContent = isOpen ? 'menu' : 'close';
    toggle.setAttribute('aria-expanded', String(!isOpen));
    toggle.setAttribute('aria-label', isOpen ? 'Abrir menu de navegação' : 'Fechar menu de navegação');
  });

  // Close mobile menu on Escape
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && !menu?.classList.contains('hidden')) {
      menu?.classList.add('hidden');
      if (icon) icon.textContent = 'menu';
      toggle?.setAttribute('aria-expanded', 'false');
      toggle?.focus();
    }
  });

  // ─── Theme Toggle ───
  const themeBtn = document.getElementById('theme-toggle');
  const themeIcon = document.getElementById('theme-icon');

  function updateThemeIcon() {
    const isDark = document.documentElement.classList.contains('dark');
    if (themeIcon) themeIcon.textContent = isDark ? 'light_mode' : 'dark_mode';
    themeBtn?.setAttribute('aria-label', isDark ? 'Mudar para tema claro' : 'Mudar para tema escuro');
  }

  // Set icon on load
  updateThemeIcon();

  themeBtn?.addEventListener('click', () => {
    const isDark = document.documentElement.classList.toggle('dark');
    localStorage.setItem('pepperoni_theme', isDark ? 'dark' : 'light');
    updateThemeIcon();
  });
</script>
