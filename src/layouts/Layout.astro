---
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
}

const {
  title,
  description = 'Mais de 70 sabores de pizzas doces, salgadas, massas e porções. Rodízio todos os dias das 18h30 às 22h30 em Maringá-PR.',
} = Astro.props;
---

<!doctype html>
<html lang="pt-BR">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title} — Pizzaria Pepperoni</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="preconnect" href="https://res.cloudinary.com" />
    <!-- Fonts: async non-render-blocking via print trick -->
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Epilogue:wght@800;900&family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap"
      media="print"
      onload="this.media='all'"
    />
    <!-- Material Symbols: only the exact variant we use (FILL=0, wght=400, opsz=24, GRAD=0) -->
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@24,400,0,0&display=swap"
      media="print"
      onload="this.media='all'"
    />
    <noscript>
      <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Epilogue:wght@800;900&family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap" />
      <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@24,400,0,0&display=swap" />
    </noscript>
    <!-- Theme: apply saved preference before paint to avoid flash -->
    <script is:inline>
      (function(){
        var t = localStorage.getItem('pepperoni_theme');
        if (t === 'dark' || (!t && window.matchMedia('(prefers-color-scheme: dark)').matches)) {
          document.documentElement.classList.add('dark');
        }
      })();
    </script>
    <!-- Open Graph -->
    <meta property="og:title" content={`${title} — Pizzaria Pepperoni`} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:locale" content="pt_BR" />
  </head>
  <body class="bg-surface text-on-surface font-body overflow-x-hidden">

    <!-- Skip to content — keyboard accessibility -->
    <a href="#main-content" class="skip-link">Ir para o conteúdo</a>

    <!-- Watermark demo overlay — pointer-events:none, não interfere com nada -->
    <div
      aria-hidden="true"
      style="position:fixed;inset:-100%;z-index:9999;pointer-events:none;user-select:none;transform:rotate(-45deg);display:flex;flex-direction:column;align-items:center;justify-content:center;gap:80px;opacity:0.25;"
    >
      {Array.from({ length: 30 }).map(() => (
        <p style="color:#DE3635;font-weight:900;font-size:18px;letter-spacing:8px;white-space:nowrap;font-family:sans-serif;margin:0;">
          SITE DEMONSTRATIVO &nbsp;&nbsp;&nbsp;&nbsp; SITE DEMONSTRATIVO &nbsp;&nbsp;&nbsp;&nbsp; SITE DEMONSTRATIVO
        </p>
      ))}
    </div>

    <Nav />
    <main id="main-content">
      <slot />
    </main>
    <Footer />

    <script>
      import Lenis from 'lenis';
      import gsap from 'gsap';
      import { ScrollTrigger } from 'gsap/ScrollTrigger';

      gsap.registerPlugin(ScrollTrigger);

      const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

      // Smooth scroll — disable if user prefers reduced motion
      if (!prefersReducedMotion) {
        const lenis = new Lenis({
          duration: 1.2,
          easing: (t) => Math.min(1, 1.001 - Math.pow(2, -10 * t)),
        });

        lenis.on('scroll', ScrollTrigger.update);
        gsap.ticker.add((time) => {
          lenis.raf(time * 1000);
        });
        gsap.ticker.lagSmoothing(0);
      }

      // Global scroll animations — skipped if reduced motion
      if (!prefersReducedMotion) {
        gsap.utils.toArray<HTMLElement>('[data-fade-up]').forEach((el) => {
          gsap.fromTo(
            el,
            { opacity: 0, y: 50 },
            {
              opacity: 1,
              y: 0,
              duration: 0.75,
              ease: 'power3.out',
              scrollTrigger: {
                trigger: el,
                start: 'top 88%',
                toggleActions: 'play none none none',
              },
            }
          );
        });

        gsap.utils.toArray<HTMLElement>('[data-fade-left]').forEach((el) => {
          gsap.fromTo(
            el,
            { opacity: 0, x: -40 },
            {
              opacity: 1,
              x: 0,
              duration: 0.75,
              ease: 'power3.out',
              scrollTrigger: {
                trigger: el,
                start: 'top 88%',
                toggleActions: 'play none none none',
              },
            }
          );
        });

        gsap.utils.toArray<HTMLElement>('[data-stagger]').forEach((parent) => {
          const children = parent.querySelectorAll('[data-stagger-item]');
          gsap.fromTo(
            children,
            { opacity: 0, y: 40 },
            {
              opacity: 1,
              y: 0,
              duration: 0.65,
              stagger: 0.1,           // 100ms stagger — within guidelines (30–50ms per item)
              ease: 'power3.out',
              scrollTrigger: {
                trigger: parent,
                start: 'top 85%',
                toggleActions: 'play none none none',
              },
            }
          );
        });
      }
    </script>
  </body>
</html>
